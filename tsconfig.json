{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "types/**/*.d.ts",
    "packages/**/*.ts",
    "setup/**/*.ts",
    "harness/**/*.ts",
    "cli/**/*.ts",
    "onchain/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "circuits/build"]
}
